# ── Model Settings ──────────────────────────────────────────
# HuggingFace embedding model (runs locally, no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# LLM for answer generation — swap for any HuggingFace causal LM
# Lightweight option (good for CPU): "google/flan-t5-base"
# Better quality (needs ~8GB RAM): "mistralai/Mistral-7B-Instruct-v0.2"
LLM_MODEL=google/flan-t5-base

# ── Vector DB ───────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION=medintel_docs

# ── Chunking ────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# ── Retrieval ───────────────────────────────────────────────
TOP_K_DOCS=4
CONFIDENCE_THRESHOLD=0.35

# ── API ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Streamlit ───────────────────────────────────────────────
STREAMLIT_PORT=8501
API_BASE_URL=http://localhost:8000
